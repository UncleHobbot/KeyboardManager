<Window x:Class="KeyboardManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:KeyboardManager.Models"
        xmlns:local="clr-namespace:KeyboardManager"
        xmlns:converters="clr-namespace:KeyboardManager.Converters"
        mc:Ignorable="d"
        Title="Keyboard Layout Manager"
        Height="500" Width="780"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StatusToBrushConverter x:Key="StatusBrush" />
        <converters:StatusToLabelConverter x:Key="StatusLabel" />
        <converters:SourcesToTextConverter x:Key="SourcesText" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Active keyboard layouts — ghosts first"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <!-- Layout list -->
        <DataGrid Grid.Row="1"
                  x:Name="LayoutGrid"
                  ItemsSource="{Binding Layouts}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Status" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                    CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusLabel}}"
                                           Foreground="White" FontWeight="SemiBold" FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Layout"
                                    Binding="{Binding DisplayName}"
                                    Width="*" />
                <DataGridTextColumn Header="Sources"
                                    Binding="{Binding Sources, Converter={StaticResource SourcesText}}"
                                    Width="280" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left"
                    Margin="0,12,0,0">
            <Button Content="Refresh"    Width="90"  Margin="0,0,8,0" Click="OnRefresh" />
            <Button Content="Remove"     Width="90"  Margin="0,0,8,0" Click="OnRemove"
                    IsEnabled="{Binding CanRemove}" />
            <Button Content="Reset"      Width="90"  Margin="0,0,8,0" Click="OnReset" />
            <Button Content="Backup now" Width="100" Margin="0,0,8,0" Click="OnBackupNow" />
        </StackPanel>

        <!-- Default-set hint, shown next to the Reset target -->
        <TextBlock Grid.Row="2"
                   x:Name="DefaultSetText"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Text="Reset target: …" />

        <!-- Default-set hint + status bar -->
        <TextBlock Grid.Row="3"
                   x:Name="StatusText"
                   Text="Ready."
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
